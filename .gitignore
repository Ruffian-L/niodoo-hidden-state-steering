# Build output
/target
**/target/
*.ptx
*.o
*.rlib

# Model weights and large binary artifacts (pinned by hash, downloaded on demand — never committed)
*.gguf
*.safetensors
*.f32
*.npy
*.bin
model/*
models/

# Python / tooling
__pycache__/
*.pyc
.venv/
.venv-*/
.uv-cache/

# Logs and scratch
*.log
/tmp/
scratch/

# OS / editor junk
.DS_Store
*.swp
*~
.vscode/

# Harness run blobs — raw dumps are heavy; keep only the human-readable evidence
# (card.md, scores.json, answers_readable.txt, *.run_timing.json are committed).
harness/runs/**/*.gz
harness/runs/**/*.jsonl
harness/runs/**/*.txt
!harness/runs/**/answers_readable.txt

# Local-only archive of dormant full_library research modules (off GitHub, kept on disk)
niodoo/legacy/

# tracked exception: redistributed Llama 3.1 tokenizer (see NOTICE.md)
!model/tokenizer.json

# raw reproduction outputs stay local (full transcripts every reproducer can read)
runs/raw/
niodoo/target-cpu/
